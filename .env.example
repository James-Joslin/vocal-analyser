# ---------------------------------------------------------------------------
# Acoustic Stress Monitor - Example Environment Configuration
# ---------------------------------------------------------------------------
# Copy this file to .env for local development and adjust values as needed.
# Do not commit real secrets, access tokens, credentials, or private endpoints.

# ---------------------------------------------------------------------------
# Web app / Node / Vite
# ---------------------------------------------------------------------------
PORT=3001
NODE_ENV=development
VITE_PORT=3001

# Local host-based development target
VITE_API_TARGET=http://localhost:8010
COGNITIVE_API_URL=http://localhost:8010

# Docker Compose service-to-service target
# VITE_API_TARGET=http://python-cognitive-api:8000
# COGNITIVE_API_URL=http://python-cognitive-api:8000

# File watching in containers/dev containers
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true

# ---------------------------------------------------------------------------
# Python API runtime
# ---------------------------------------------------------------------------
TZ=UTC
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
HF_HOME=/app/.cache/huggingface

# ---------------------------------------------------------------------------
# Model configuration
# ---------------------------------------------------------------------------
WHISPER_MODEL_ID=large-v3-turbo
WAV2VEC_EMOTION_MODEL_ID=Dpngtm/wav2vec2-emotion-recognition
SENTIMENT_MODEL_ID=distilbert-base-uncased-finetuned-sst-2-english
PRELOAD_MODELS=1
NEUTRAL_PITCH_HZ=190.0
